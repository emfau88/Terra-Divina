{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "ignoreDeprecations": "5.0",
    "baseUrl": "./src",
    "paths": {
      "@game/*": ["game/*"],
      "@styles/*": ["styles/*"]
    }
  },
  "include": ["src"]
}
